---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base title="Home" description="A minimal, SEO-ready static site template built with Astro.">
  <h1>Welcome</h1>
  <p>A fast, SEO-ready static site template. Edit content in <code>src/content/blog/</code>.</p>

  <section>
    <h2>Recent Posts</h2>
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>
            <span class="post-title">{post.data.title}</span>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  h1 { margin-bottom: 0.5rem; }
  h2 { margin-top: 2rem; margin-bottom: 1rem; font-size: 1.25rem; }
  .post-list { list-style: none; }
  .post-list li { padding: 0.5rem 0; border-bottom: 1px solid #f0f0f0; }
  .post-list a { display: flex; justify-content: space-between; align-items: center; }
  .post-title { font-weight: 500; }
  time { font-size: 0.85rem; color: #888; }
</style>
